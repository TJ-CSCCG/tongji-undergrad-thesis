\ProvidesFile{tongji-cjk-font-adobe.def}[2026/05/19 v1.4.3 Adobe CJK fonts definition (TongjiThesis)]

\setCJKmainfont{AdobeSongStd-Light}
  [ BoldFont = AdobeHeitiStd-Regular, ItalicFont = AdobeKaitiStd-Regular ]
\setCJKsansfont{AdobeHeitiStd-Regular}  [ AutoFakeBold = 3 ]
\setCJKmonofont{AdobeFangsongStd-Regular}

\setCJKfamilyfont{zhsong}{AdobeSongStd-Light}
  [ BoldFont = AdobeHeitiStd-Regular, ItalicFont = AdobeKaitiStd-Regular ]
\setCJKfamilyfont{zhhei}{AdobeHeitiStd-Regular}  [ AutoFakeBold = 3 ]
\setCJKfamilyfont{zhkai}{AdobeKaitiStd-Regular}
\setCJKfamilyfont{zhfs}{AdobeFangsongStd-Regular}

\NewDocumentCommand{\songti}   {} { \CJKfamily{zhsong} }
\NewDocumentCommand{\heiti}    {} { \CJKfamily{zhhei}  }
\NewDocumentCommand{\kaishu}   {} { \CJKfamily{zhkai}  }
\NewDocumentCommand{\fangsong} {} { \CJKfamily{zhfs}   }
\endinput
